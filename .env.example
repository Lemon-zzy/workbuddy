# 知乎开放平台 API 配置
ZHIHU_ACCESS_KEY=your_access_key_here
ZHIHU_API_BASE=https://api.zhihu.com
ZHIHU_SEARCH_PATH=/search_v3

# 后端服务
APP_HOST=127.0.0.1
APP_PORT=8000
DEBUG=true

# 数据库（开发期先用 SQLite，生产再切 MySQL）
DATABASE_URL=sqlite:///./workbuddy.db

# 同步配置
SYNC_KEYWORD=workbuddy
SYNC_CRON_HOUR=2
SYNC_CRON_MINUTE=0
